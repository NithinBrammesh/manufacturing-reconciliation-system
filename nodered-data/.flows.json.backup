    {
        "id": "c9f94beca590f168",
        "type": "function",
        "z": "9d4db24319f4b0b7",
        "name": "function 16",
        "func": "var savedFileOnly = msg.fileOnly;\nvar savedFilename = msg.filename;\n\nvar lines = msg.payload.split('\\n');\nvar data = {};\n\nlines.forEach(function (line) {\n\n    line = line.trim();\n\n    if (line) {\n\n        var idx = line.indexOf(',');\n\n        if (idx !== -1) {\n\n            var key = line.substring(0, idx).trim();\n\n            var value = line.substring(idx + 1)\n                .trim()\n                .replace(/\"/g, '');\n\n            data[key] = value;\n        }\n    }\n});\n\nmsg.payload = JSON.stringify({\n\n    barcode: data[\"Barcode\"],\n\n    result: data[\"Result\"],\n\n    panelId: data[\"Panel ID\"],\n\n    programName: data[\"Program Name\"],\n\n    machine: \"FCR2\",\n\n    line: \"LINE2\",\n\n    sourceType: \"FCR\",\n\n    timestamp: data[\"Test End Time\"]\n\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
