    {
        "id": "891022bb8a29095c",
        "type": "function",
        "z": "9d4db24319f4b0b7",
        "name": "function 3",
        "func": "var savedFileOnly = msg.fileOnly;\nvar savedFilename = msg.filename;\nvar lines = msg.payload.split('\\n');\nvar data = {};\n\nlines.forEach(function (line) {\n    line = line.trim();\n    if (line) {\n        var idx = line.indexOf(',');\n        if (idx !== -1) {\n            var key = line.substring(0, idx).trim();\n            var value = line.substring(idx + 1).trim().replace(/\"/g, '');\n            data[key] = value;\n        }\n    }\n});\n\nvar jsonPayload = JSON.stringify({\n    barcode: data[\"Barcode\"],\n    result: data[\"Result\"],\n    panelId: data[\"Panel ID\"],\n    programName: data[\"Program Name\"],\n    source: \"AOI\"\n});\n\n// msg1 goes to kafkajs-producer (needs JSON payload)\nvar msg1 = { payload: jsonPayload };\n\n// msg2 goes to mark processed (needs fileOnly)\nvar msg2 = {\n    payload: savedFileOnly,\n    fileOnly: savedFileOnly,\n    filename: savedFilename\n};\n\nreturn [msg1, msg2];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 860,
        "wires": [
