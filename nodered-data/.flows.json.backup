    {
        "id": "ba09e79655016b05",
        "type": "function",
        "z": "9d4db24319f4b0b7",
        "name": "AOI2 Extract ",
        "func": "msg.filename = msg.payload;\n\nlet parts = msg.payload.split(\"/\");\nmsg.fileOnly = parts[parts.length - 1];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 650,
        "y": 2580,
        "wires": [
            [
                "6f99cad297b4c5dc",
                "ebb61274d525e396"
            ]
        ]
    },
    {
        "id": "10137ed5d17afa4c",
        "type": "function",
        "z": "9d4db24319f4b0b7",
        "name": "function 10",
        "func": "var savedFileOnly = msg.fileOnly;\nvar savedFilename = msg.filename;\n\nvar lines = msg.payload.split('\\n');\nvar boardData = null;\nvar headers = null;\n\nfor (var i = 0; i < lines.length; i++) {\n\n    var line = lines[i].trim();\n\n    if (line === 'Board') {\n\n        headers = lines[i + 1].trim().split(',');\n\n        var values = lines[i + 2]\n            ? lines[i + 2].trim().split(',')\n            : [];\n\n        if (values.length > 0) {\n\n            boardData = {};\n\n            headers.forEach(function (h, idx) {\n\n                boardData[h.trim()] =\n                    values[idx]\n                        ? values[idx].trim()\n                        : '';\n\n            });\n\n        }\n\n        break;\n    }\n}\n\nif (!boardData) {\n    return null;\n}\n\nvar jsonPayload = JSON.stringify({\n\n    barcode: boardData[\"MasterBarcode\"],\n\n    inspectionDateTime:\n        boardData[\"InspectionDateTime\"],\n\n    result:\n        boardData[\"PCBResult\"],\n\n    side:\n        boardData[\"Side\"],\n\n    machine: \"SPI2\",\n\n    line: \"LINE2\",\n\n    sourceType: \"SPI\",\n\n    timestamp:\n        boardData[\"InspectionDateTime\"]\n\n});\n\n\n// Output 1 -> Kafka\n\nvar msg1 = {\n\n    payload: jsonPayload\n\n};\n\n\n// Output 2 -> Redis Mark Processed\n\nvar msg2 = {\n\n    payload: savedFileOnly,\n\n    fileOnly: savedFileOnly,\n\n    filename: savedFilename\n\n};\n\nreturn [msg1, msg2];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 2840,
        "wires": [
            [
                "38b80a79a7b9d229",
                "24326d252cb047d9"
            ],
            [
                "168947b6b07f3dcf"
            ]
        ]
    },
