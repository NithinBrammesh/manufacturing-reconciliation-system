    {
        "id": "dd59532407ab193e",
        "type": "watch",
        "z": "9d4db24319f4b0b7",
        "name": "SPI1-watch",
        "files": "/real-data/AOI3D1",
        "recursive": "",
        "x": 110,
        "y": 1180,
        "wires": [
            [
                "7bd10b7c187f98ce",
