    {
        "id": "8bc89bc3053fc6be",
        "type": "watch",
        "z": "9d4db24319f4b0b7",
        "name": "AOI2-watch",
        "files": "/real-data/AOI2",
        "recursive": "",
        "x": 130,
        "y": 2220,
        "wires": [
            [
                "4b369f2db99a3370",
                "0b4cbe5757548524"
