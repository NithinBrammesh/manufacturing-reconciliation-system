    {
        "id": "f0fadc91031fc189",
        "type": "function",
        "z": "9d4db24319f4b0b7",
        "name": "function 6",
        "func": "var lines = msg.payload.split('\\n');\nvar boardData = null;\nvar headers = null;\n\nfor (var i = 0; i < lines.length; i++) {\n    var line = lines[i].trim();\n    if (line === 'Board') {\n        // Next line is headers, line after is data\n        headers = lines[i + 1].trim().split(',');\n        var values = lines[i + 2] ? lines[i + 2].trim().split(',') : [];\n        if (values.length > 0) {\n            boardData = {};\n            headers.forEach(function (h, idx) {\n                boardData[h.trim()] = values[idx] ? values[idx].trim() : '';\n            });\n        }\n        break;\n    }\n}\n\nif (!boardData) {\n    return null; // skip if no board data\n}\n\nmsg.payload = JSON.stringify({\n    barcode: boardData[\"MasterBarcode\"],\n    inspectionDateTime: boardData[\"InspectionDateTime\"],\n    result: boardData[\"PCBResult\"],\n    side: boardData[\"Side\"],\n    source: \"SPI\"\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 1360,
        "wires": [
            [
                "b9ccdf26accbd018",
                "de0e797dcab71335"
            ]
        ]
    },
